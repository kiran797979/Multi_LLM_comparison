# AI Content Generator Environment Variables
# Copy this file to .env and fill in your actual API key

# OpenRouter API Key (Required)
# Get yours from: https://openrouter.ai/
OPENROUTER_API_KEY="your-openrouter-api-key"

# Optional: Set custom model preferences
# Remove the # to enable these settings
# DEFAULT_MODEL="deepseek/deepseek-chat"
# DEFAULT_TEMPERATURE=0.7

# Optional: Comma-separated list of allowed frontend origins for FastAPI CORS
# Example: CORS_ORIGINS="http://localhost:5173,https://multi-llm-comparison.vercel.app"
# CORS_ORIGINS="http://localhost:5173"

# Optional: Streamlit configuration
# STREAMLIT_PORT=8501
# STREAMLIT_HOST=localhost
